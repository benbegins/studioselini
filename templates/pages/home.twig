{% extends "layout.twig" %}

{% block content %}

    {# Hero #}
    <section class="relative overflow-x-clip mb-16">
        <div class="container overflow-hidden relative z-10">
            <div class="text-center">

                <div class="leading-none text-terracotta font-titling-subhead">
                    <p class="text-body-m sm:text-body-xl">Pratiquer le yoga, le Pilates ou le Reformer</p>
                    <div class="font-titling-display mt-1 text-h1mobile sm:text-h1 sm:mt-2" v-scope="HomeAnim()" @vue:mounted="init($el)">
                    </div>
                </div>
                
                <div class="flex gap-2 justify-center items-center mt-4 flex-wrap">
                    {% if studio_page_url %}
                        {% include "components/btns.twig" with {secondary: true, text: "Découvrir le studio", url: options.pages.studio} %}
                    {% endif %}
                </div>

                <div class="flex justify-center pointer-events-none relative z-10">
                    <img 
                        src="{{theme.uri}}/src/images/yoga_reformers.webp" 
                        loading="lazy" 
                        alt="Tiffany Studio Selíni" 
                        class="w-[30rem] max-w-none -translate-y-2 sm:w-[70rem] sm:-translate-y-4"
                    >
                </div>
            </div>
        </div>
        {# Mandala #}
        <div class="pointer-events-none lg:absolute lg:inset-0 lg:translate-y-1/3">
            <div class="lg:animate-spin-slow">
                <img
                    src="{{theme.uri}}/src/images/mandala.svg"
                    loading="lazy"
                    alt=""
                    class="pointer-events-none opacity-10 absolute w-full top-1/2 left-1/2 -translate-x-1/2 -z-10 scale-[160%] -translate-y-2/3 sm:scale-[130%] lg:scale-100 lg:-translate-y-1/2 lg:-top-full lg:max-w-[65rem]"
                >
            </div>
        </div>
        {# BG Gradient #}
        <div class="absolute opacity-50 -z-10 w-[250vw] h-[250vw] top-1/2 left-0 -translate-x-1/3 -translate-y-1/2 sm:w-[100vw] sm:h-[100vw] sm:-translate-y-2/3" style="background: radial-gradient(50% 50% at 50% 50%, #BFA597 0%, rgba(191, 165, 151, 0.00) 100%);"></div>
    </section>



    {# Plannings #}
    {% set plannings = post.meta('plannings') %}
    {% if plannings %}
    <section class="pb-section">
        <div class="container">
            <div class="grid gap-6 md:grid-cols-2">

                {# Planning Yoga & Pilates mat #}
                {% if options.pages.planning %}
                    <div class="bg-light p-6 rounded-2xl lg:p-8">
                        <div class="flex justify-between gap-8 items-center">
                            <div>
                                <h2 class="text-body-l font-extralight">Planning</h2>
                                <h3 class="text-h2 leading-tight">Yoga & Pilates mat</h3>
                            </div>
                            <a href="{{options.pages.planning}}">
                                <img src="{{theme.uri}}/src/images/icon-circle-arrow.svg" alt="Icon flèche" class="w-16 transition-opacity duration-200 lg:hover:opacity-80">
                            </a>
                        </div>
                        <div class="w-full aspect-video overflow-hidden mt-6 rounded-lg">
                            <a href="{{options.pages.planning}}">
                                {% if plannings.image_yoga %}
                                    {{ function('wp_get_attachment_image', plannings.image_yoga.id, 'large', false, {class: "w-full h-full object-cover"}) }}
                                {% elseif options.placeholder %}
                                    {{ function('wp_get_attachment_image', options.placeholder.id, 'large', false, {class: "w-full h-full object-cover"}) }}
                                {% endif %}
                            </a>
                        </div>
                    </div>
                {% endif %}
                
                {# Planning Reformer #}
                {% if options.pages.planning_reformers %}
                    <div class="bg-light p-6 rounded-2xl lg:p-8">
                        <div class="flex justify-between gap-8 items-center">
                            <div>
                                <h2 class="text-body-l font-extralight">Planning</h2>
                                <h3 class="text-h2 leading-tight">Reformer Pilates</h3>
                            </div>
                            <a href="{{options.pages.planning_reformers}}">
                                <img src="{{theme.uri}}/src/images/icon-circle-arrow.svg" alt="Icon flèche" class="w-16 transition-opacity duration-200 lg:hover:opacity-80">
                            </a>
                        </div>
                        <div class="w-full aspect-video overflow-hidden mt-6 rounded-lg">
                            <a href="{{options.pages.planning_reformers}}">
                                {% if plannings.image_reformer %}
                                    {{ function('wp_get_attachment_image', plannings.image_reformer.id, 'large', false, {class: "w-full h-full object-cover"}) }}
                                {% elseif options.placeholder %}
                                    {{ function('wp_get_attachment_image', options.placeholder.id, 'large', false, {class: "w-full h-full object-cover"}) }}
                                {% endif %}
                            </a>
                        </div>
                    </div>
                {% endif %}
            </div>
            
            <div class="text-body-s leading-none mt-2">
                <p><sup>(1)</sup> Vous pouvez payer en 3x sans frais. </p>
                <p><sup>(2)</sup> Il y aura une réduction du nombre de cours pendant les vacances scolaires. </p>
                <p><sup>(3)</sup> Notre studio sera fermé du 15/07 au 01/09.</p>
            </div>
        </div>
    </section>
    {% endif %}
    
    


   
   {# Presentation #}
   {% set presentation = post.meta('introduction') %}
   {% if presentation %}
    <section class="pb-section">
            <div class="container flex flex-col gap-10 md:grid md:grid-cols-2 md:items-center">
                <div class="w-full aspect-square rounded-2xl overflow-hidden lg:w-5/6 lg:aspect-[4/5]">
                    {{ function('wp_get_attachment_image', post.thumbnail.id, 'large', false, {'class': 'w-full h-full object-cover'}) }}
                </div>
                <div>
                    <p class="text-body-l leading-snug mb-6">{{presentation.presentation}}</p>
                    <p>{{presentation.introduction}}</p>
                </div>
            </div>
        </section>
   {% endif %}

    {% include "components/reviews.twig" %}
    
{% endblock %}
